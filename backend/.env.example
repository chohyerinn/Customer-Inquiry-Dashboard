# 실제 값은 서버의 .env 파일에만 두고, git에는 절대 커밋하지 않는다.
# docker compose가 이 이름들을 ${VAR}로 주입한다.

# DB
POSTGRES_PASSWORD=change-me

# CLOVA Studio (HyperCLOVA X)
CLOVA_API_KEY=

# Telegram 알림 봇
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail IMAP 폴러 (이메일 문의 수집)
IMAP_USER=help@example.com
IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_USER=help@example.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
BACKEND_URL=http://localhost:8000
POLL_INTERVAL_SEC=60
