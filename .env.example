# 데이터 계층 — Ncloud 관리형 서비스 (Private Subnet, private 엔드포인트)
DATABASE_URL=postgresql://ai_user:<DB_PASSWORD>@<PG_PRIVATE_HOST>:5432/ai_cs
REDIS_URL=redis://:<REDIS_PASSWORD>@<REDIS_PRIVATE_HOST>:6379/0

# CLOVA Studio API
CLOVA_API_KEY=nv-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot 알림
TELEGRAM_BOT_TOKEN=000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=000000000

# Gmail IMAP (앱 비밀번호 16자리, 공백 제거)
IMAP_USER=your_account@gmail.com
IMAP_PASSWORD=xxxxxxxxxxxxxxxx
